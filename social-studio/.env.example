# The Apologify app that renders the real designs (single source of truth).
# Local dev/preview by default; point at prod only if the endpoint is deployed.
APP_URL=http://localhost:4321
# Shared secret with the app's STUDIO_API_KEY (protects POST /api/social-card).
STUDIO_API_KEY=studio_xxxxx

# Claude Haiku 4.5 — writes on-card apology text + captions (English).
# Optional: omit and use --content <json> to supply content yourself (no key).
ANTHROPIC_API_KEY=sk-ant-xxxxx
# Post Bridge — publishes the generated image + caption.
# Get one at https://www.post-bridge.com/dashboard/api-keys
POST_BRIDGE_API_KEY=pb_live_xxxxx
