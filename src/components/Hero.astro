---
// Hero: headline on the left, a real apology-page mockup on the right — the
// product shows itself instead of being described. Static (CSS-only) so it
// paints instantly; the live multi-design demo lives further down the page.
import { THEMES } from "../lib/themes.js";
const designCount = THEMES.length;
---
<section class="relative w-screen left-1/2 right-1/2 -mx-[50vw] bg-gradient-to-br from-primary/10 via-base-100 to-secondary/10 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6 py-20 sm:py-28 grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
    <!-- Left: message -->
    <div class="text-center lg:text-left">
      <div class="badge badge-outline gap-2 bg-base-100/80 backdrop-blur-sm py-3 px-4 shadow-sm">
        <span class="w-2 h-2 bg-success rounded-full" aria-hidden="true"></span>
        <span class="text-sm font-medium text-base-content/70 font-sans">AI-written · beautifully designed</span>
      </div>

      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-semibold text-base-content tracking-tight leading-[1.05] mt-6 mb-6" style="text-wrap: balance;">
        Don't just say<br />
        <span class="text-primary">I'm sorry.</span>
      </h1>

      <p class="text-lg text-base-content/70 max-w-md mx-auto lg:mx-0 mb-8 font-sans">
        Turn your apology into a page they'll actually open. Tell us what happened,
        pick a design you love, and send a link they can read, accept, and keep.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start mb-6">
        <a href="/generator" class="btn btn-primary btn-lg">
          Make my apology page
          <svg class="w-5 h-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5l7 7-7 7M4 12h14"></path>
          </svg>
        </a>
        <a href="#showcase" class="btn btn-ghost btn-lg">See the designs</a>
      </div>

      <div class="flex flex-wrap justify-center lg:justify-start gap-x-6 gap-y-2 text-sm text-base-content/70 font-sans">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-success" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
          Free to create
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-success" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
          {designCount} designs to choose
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-success" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
          Share with one link
        </span>
      </div>
    </div>

    <!-- Right: a real apology page, shown not told -->
    <div class="relative mx-auto w-full max-w-md">
      <div class="absolute inset-0 translate-x-3 translate-y-4 rounded-lg bg-base-300/50 rotate-2" aria-hidden="true"></div>
      <article class="relative bg-[#fffdf8] border border-[#ece0c8] rounded-lg shadow-2xl px-7 py-9 sm:px-10 sm:py-12 -rotate-1">
        <p class="text-[0.65rem] uppercase tracking-[0.35em] text-[#b3925a] mb-3 text-center">An apology</p>
        <h2 class="font-display text-2xl sm:text-3xl text-[#3a2f22] text-center leading-tight" style="text-wrap: balance;">For missing the night that mattered</h2>
        <div class="mx-auto w-14 h-px bg-[#cdb486] my-5" aria-hidden="true"></div>
        <p class="text-[#5a4a36] mb-3 font-display text-lg">Dear Mia,</p>
        <p class="text-[#4a3d2c] leading-[1.8] text-[15px] font-display">
          I know tonight mattered to you, and I wasn't there. No excuse — I let work
          crowd out the one place I'd promised to be.
        </p>
        <p class="mt-8 text-right text-4xl font-cursive text-[#7a5c34]">Sam</p>
      </article>
    </div>
  </div>
</section>
