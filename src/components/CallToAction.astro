---
import { THEMES } from "../lib/themes.js";
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Don’t just say it. Show it.",
  description = "Turn your apology into a page they’ll actually open — written for you, designed by you, shared in one link."
} = Astro.props;

const designCount = THEMES.length;
---

<!-- CTA Section destacado con diseño moderno -->
<div class="relative my-16">
  <!-- Background con gradiente y efectos -->
  <div class="relative bg-primary rounded-3xl overflow-hidden shadow-2xl">
    <!-- Elementos decorativos de fondo -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute -top-20 -right-20 w-40 h-40 bg-primary-content/10 rounded-full blur-xl"></div>
      <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-primary-content/10 rounded-full blur-xl"></div>
      <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-60 h-60 bg-primary-content/5 rounded-full blur-2xl"></div>
    </div>

    <!-- Patrón de puntos decorativo -->
    <div class="absolute inset-0 opacity-10 text-primary-content">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="dots" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="20" cy="20" r="2" fill="currentColor"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#dots)"/>
      </svg>
    </div>
    
    <!-- Contenido del CTA -->
    <div class="relative px-6 py-16 md:px-12 md:py-20 text-center">
      <div class="max-w-2xl mx-auto space-y-8">
        <!-- Badge superior -->
        <div class="badge badge-lg gap-2 bg-primary-content/20 border-primary-content/30 text-primary-content backdrop-blur-sm py-3">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm font-medium">Free · under a minute</span>
        </div>
        
        <h2 class="text-3xl md:text-5xl font-bold text-primary-content leading-tight tracking-tight">
          {title}
        </h2>
        
        <p class="text-lg md:text-xl text-primary-content/80 leading-relaxed max-w-xl mx-auto">
          {description}
        </p>
        
        <!-- Botón CTA destacado -->
        <div class="pt-4">
          <a href="/generator" class="btn btn-lg group relative overflow-hidden bg-base-100 text-primary hover:bg-base-200 border-0 rounded-2xl shadow-xl hover:shadow-2xl hover:scale-105 gap-3 h-auto py-5 px-10 text-xl">
            <!-- Efecto de brillo -->
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-base-100/20 to-transparent -skew-x-12 transform translate-x-[-100%] group-hover:translate-x-[200%] transition-transform duration-1000"></div>

            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            <span class="relative">Make my apology page</span>
            <svg class="w-6 h-6 text-primary group-hover:translate-x-1 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
        
        <!-- Elementos de confianza -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 pt-6 text-primary-content/80">
          <div class="flex items-center space-x-2">
            <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-medium">Free to create</span>
          </div>
          <div class="flex items-center space-x-2">
            <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-medium">{designCount} designs</span>
          </div>
          <div class="flex items-center space-x-2">
            <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-medium">Share with a link</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
