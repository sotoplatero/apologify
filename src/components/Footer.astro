---
import { tones, recipients } from "../lib/apologyData.js";

const currentYear = new Date().getFullYear();

const topTones = tones.filter((t) => t.value !== "other").slice(0, 6);
---

<footer
  class="bg-base-200 border-t border-base-300 text-base-content"
>
  <!-- Top Section: Logo + Social -->
  <div class="w-full max-w-screen-xl mx-auto px-4 pt-12 pb-8">
    <!-- Middle Section: Link Columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 font-sans">
      <!-- Apologify (Product + Company merged) -->
      <div>
        <div
          class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-4"
        >
          <div>
            <a
              href="/"
              class="text-2xl font-bold text-base-content flex items-center gap-2 font-serif"
            >
              <span class="text-3xl">💌</span>
              Apologify
            </a>
            <p class="text-sm text-base-content/60 mt-2 max-w-md font-sans">
              Turn a heartfelt apology into a beautiful, shareable web page in
              seconds. Free to create — pick a design and send the link.
            </p>
          </div>
        </div>
        <ul class="space-y-2.5 text-sm">
          <li>
            <a
              href="/generator"
              class="text-base-content/70 hover:text-primary transition-colors"
              >Apology Builder</a
            >
          </li>
          <li>
            <a
              href="/designs"
              class="text-base-content/70 hover:text-primary transition-colors"
              >Designs</a
            >
          </li>
          <li>
            <a
              href="/examples"
              class="text-base-content/70 hover:text-primary transition-colors"
              >Browse Examples</a
            >
          </li>
          <li>
            <a
              href="/articles"
              class="text-base-content/70 hover:text-primary transition-colors"
              >Articles</a
            >
          </li>
          <li>
            <a
              href="/about"
              class="text-base-content/70 hover:text-primary transition-colors"
              >About Us</a
            >
          </li>
          <li>
            <a
              href="/contact"
              class="text-base-content/70 hover:text-primary transition-colors"
              >Contact</a >
          </li>
        </ul>
      </div>

      <!-- Generators by Recipient -->
      <div>
        <h3
          class="text-sm font-semibold text-base-content uppercase tracking-wider mb-4"
        >
          Generators
        </h3>
        <ul class="space-y-2.5 text-sm">
          {
            recipients.map((r) => (
              <li>
                <a
                  href={`/generator/${r.value}`}
                  class="text-base-content/70 hover:text-primary transition-colors"
                >
                  Sorry to {r.label.toLowerCase()}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Directory by Recipient -->
      <div>
        <h3
          class="text-sm font-semibold text-base-content uppercase tracking-wider mb-4"
        >
          Directory
        </h3>
        <ul class="space-y-2.5 text-sm">
          {
            recipients.map((r) => (
              <li>
                <a
                  href={`/examples?recipient=${r.value}`}
                  class="text-base-content/70 hover:text-primary transition-colors"
                >
                  {r.label} examples
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Tones -->
      <div>
        <h3
          class="text-sm font-semibold text-base-content uppercase tracking-wider mb-4"
        >
          Tones
        </h3>
        <ul class="space-y-2.5 text-sm">
          {
            topTones.map((t) => (
              <li>
                <a
                  href={`/examples?tone=${t.value}`}
                  class="text-base-content/70 hover:text-primary transition-colors"
                >
                  {t.label} apologies
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Section -->
  <div class="border-t border-base-300">
    <div
      class="w-full max-w-screen-xl mx-auto px-4 py-5 flex flex-col sm:flex-row justify-between items-center gap-2 text-sm text-base-content/50 font-sans"
    >
      <p>&copy; {currentYear} Apologify. All rights reserved.</p>
      <p>
        Made with <span class="text-error">&#9829;</span> to help mend relationships
      </p>
    </div>
  </div>
</footer>
