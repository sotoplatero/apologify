---
import HeaderAuth from "./HeaderAuth.svelte";
---

<header
  class="sticky top-0 z-50 bg-base-100/95 backdrop-blur-sm border-b border-base-300"
>
  <div
    class="w-full max-w-screen-xl mx-auto px-4 py-3 flex justify-between items-center gap-3"
  >
    <!-- Logo -->
    <a href="/" class="text-xl font-semibold flex items-center gap-1.5 font-serif shrink-0">
      <span class="text-2xl sm:text-3xl leading-none" role="img" aria-label="Apology">💌</span>
      <span>Apologify</span>
    </a>

    <!-- Nav: just the primary action + auth -->
    <nav class="flex items-center gap-2 sm:gap-3">
      <a href="/generator" class="btn btn-primary btn-sm gap-1.5">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"
          ></path>
        </svg>
        <span class="sm:hidden">Write</span>
        <span class="hidden sm:inline">Write an apology</span>
      </a>
      <HeaderAuth client:load />
    </nav>
  </div>
</header>
