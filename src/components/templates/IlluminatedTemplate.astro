---
import ApologyActions from "../ApologyActions.svelte";
const { title, heading, paragraphs, senderName, slug, acceptedAt, preview } = Astro.props;

// Split the first paragraph so we can render an illuminated drop cap on its
// opening letter. The body arrives as HTML strings, so we peel the leading
// text node off the very first paragraph.
const body: string[] = Array.isArray(paragraphs) ? paragraphs : [];
const firstRaw = (body[0] ?? "").toString();
const rest = body.slice(1);
const capMatch = firstRaw.match(/^(\s*(?:<[^>]+>\s*)*)([A-Za-z])([\s\S]*)$/);
const capLead = capMatch ? capMatch[1] : "";
const dropCap = capMatch ? capMatch[2] : "";
const firstAfterCap = capMatch ? capMatch[3] : firstRaw;
---
<main
  class="illum min-h-screen w-full flex flex-col items-center justify-center px-5 py-16"
  style="background:
    radial-gradient(ellipse at 25% 10%, #f6ecd0 0%, #ecdcb4 45%, #dcc796 100%);"
>
  <div class="w-full max-w-2xl">
    <div class="illum-eyebrow text-center mb-6">
      <span class="text-[0.68rem] tracking-[0.4em] uppercase text-[#8a5a1a]">✝ Illuminated ✝</span>
    </div>

    <article class="illum-page relative px-8 py-12 sm:px-14 sm:py-16">
      <!-- Hand-drawn filigree border that "draws in" on load -->
      <svg class="illum-border" viewBox="0 0 400 560" preserveAspectRatio="none" aria-hidden="true">
        <rect x="10" y="10" width="380" height="540" rx="4" />
        <rect x="20" y="20" width="360" height="520" rx="2" />
        <path class="vine" d="M20 40 C 6 60, 6 90, 20 110 C 34 130, 34 160, 20 180" />
        <path class="vine" d="M380 40 C 394 60, 394 90, 380 110 C 366 130, 366 160, 380 180" />
        <path class="vine" d="M20 380 C 6 400, 6 430, 20 450 C 34 470, 34 500, 20 520" />
        <path class="vine" d="M380 380 C 394 400, 394 430, 380 450 C 366 470, 366 500, 380 520" />
        <circle class="gild-dot" cx="20" cy="20" r="4" />
        <circle class="gild-dot" cx="380" cy="20" r="4" />
        <circle class="gild-dot" cx="20" cy="540" r="4" />
        <circle class="gild-dot" cx="380" cy="540" r="4" />
      </svg>

      <div class="illum-inner relative">
        <div class="text-center mb-8">
          <p class="illum-reveal r1 text-[0.66rem] uppercase tracking-[0.45em] text-[#9a6a24] mb-3">An apology</p>
          <h1 class="illum-reveal r2 illum-title text-3xl sm:text-4xl leading-tight">{title}</h1>
          <div class="illum-reveal r2 mt-5 mx-auto illum-rule"></div>
        </div>

        {heading && <p class="illum-reveal r3 illum-heading text-lg sm:text-xl mb-6">{heading}</p>}

        <div class="illum-reveal r4 illum-body space-y-5 text-lg leading-[1.85]">
          {dropCap ? (
            <p>
              <span set:html={capLead} />
              <span class="drop-cap">{dropCap}<span class="drop-shimmer" aria-hidden="true"></span></span>
              <span set:html={firstAfterCap} />
            </p>
          ) : (
            <p set:html={firstRaw} />
          )}
          {rest.map((p: string) => <p set:html={p} />)}
        </div>

        {senderName && <p class="illum-reveal r5 illum-sign mt-12 text-right text-3xl sm:text-4xl">{senderName}</p>}

        <div class="illum-reveal r6 mt-12 pt-8 border-t border-[#d9c084] flex justify-center">
          <ApologyActions client:load slug={slug} acceptedAt={acceptedAt} preview={preview}
            acceptLabel="Bless this 💛"
            primaryClass="px-6 py-3 rounded-sm bg-[#8a5a1a] text-[#fbf3dc] font-medium tracking-wide hover:bg-[#6f4712] transition-colors"
            secondaryClass="px-6 py-3 rounded-sm border border-[#c39a4a] text-[#8a5a1a] hover:bg-[#f2e6c4] transition-colors"
            mutedClass="text-sm text-[#9a6a24]" />
        </div>
      </div>
    </article>

    <a href="/generator" class="illum-reveal r6 block text-center mt-8 text-xs tracking-wide text-[#9a6a24] hover:text-[#6f4712] transition-colors">Made on apologify.com — write your own →</a>
  </div>
</main>

<style>
  .illum {
    font-family: "Lora", ui-serif, Georgia, serif;
  }

  .illum-page {
    background:
      /* faint vellum fibers */
      repeating-linear-gradient(0deg, rgba(120, 90, 40, 0.025) 0px, rgba(120, 90, 40, 0.025) 1px, transparent 1px, transparent 4px),
      radial-gradient(ellipse at 50% 0%, #fffbf0 0%, #f7edd4 100%);
    box-shadow: 0 26px 70px -22px rgba(90, 60, 20, 0.5);
    border: 1px solid #e6d3a4;
  }

  .illum-border {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    fill: none;
    stroke: #b98d3a;
    stroke-width: 1.5;
    pointer-events: none;
    opacity: 0.85;
  }
  .illum-border rect,
  .illum-border .vine {
    stroke-dasharray: 2400;
    stroke-dashoffset: 2400;
    animation: draw-in 2.4s ease-out 0.15s forwards;
  }
  .illum-border .vine { stroke: #a5701f; }
  .illum-border .gild-dot {
    fill: #d4a531;
    stroke: none;
    opacity: 0;
    animation: gild-appear 0.6s ease-out 2.2s forwards;
  }

  .illum-title {
    font-family: "Fraunces", "Lora", ui-serif, Georgia, serif;
    font-weight: 600;
    color: #4a3410;
    text-wrap: balance;
    letter-spacing: 0.01em;
  }
  .illum-rule {
    width: 4.5rem;
    height: 2px;
    background: linear-gradient(90deg, transparent, #c39a4a, transparent);
  }
  .illum-heading { color: #6a4d1e; font-style: italic; }
  .illum-body { color: #40331c; }
  .illum-sign {
    font-family: "Dancing Script", cursive;
    color: #8a5a1a;
  }

  .drop-cap {
    position: relative;
    float: left;
    font-family: "Fraunces", "Lora", ui-serif, Georgia, serif;
    font-weight: 700;
    font-size: 4.6rem;
    line-height: 0.82;
    padding: 0.08em 0.14em 0 0;
    margin-right: 0.04em;
    color: #b0121a; /* deep vermilion */
    text-shadow:
      0 1px 0 #d4a531,
      1px 2px 1px rgba(120, 30, 10, 0.35);
    background: linear-gradient(160deg, #c8912e 0%, #f3d878 35%, #b0121a 36%, #8f0d14 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  /* gold shimmer sweeping across the drop cap */
  .drop-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255, 246, 200, 0.9) 50%, transparent 60%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 250% 100%;
    animation: shimmer 4.5s ease-in-out 2.6s infinite;
  }

  /* staggered reveal */
  .illum-reveal {
    opacity: 0;
    transform: translateY(10px);
    animation: rise 0.9s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
  }
  .r1 { animation-delay: 0.5s; }
  .r2 { animation-delay: 0.7s; }
  .r3 { animation-delay: 0.9s; }
  .r4 { animation-delay: 1.1s; }
  .r5 { animation-delay: 1.4s; }
  .r6 { animation-delay: 1.6s; }

  @keyframes rise {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes draw-in {
    to { stroke-dashoffset: 0; }
  }
  @keyframes gild-appear {
    to { opacity: 1; }
  }
  @keyframes shimmer {
    0%, 100% { background-position: 250% 0; }
    50% { background-position: -50% 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .illum-reveal,
    .illum-border rect,
    .illum-border .vine,
    .illum-border .gild-dot,
    .drop-shimmer {
      animation: none !important;
    }
    .illum-reveal { opacity: 1; transform: none; }
    .illum-border rect, .illum-border .vine { stroke-dashoffset: 0; }
    .illum-border .gild-dot { opacity: 1; }
    .drop-shimmer { display: none; }
  }
</style>
