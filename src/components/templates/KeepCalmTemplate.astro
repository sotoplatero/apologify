---
import ApologyActions from "../ApologyActions.svelte";
const { title, heading, paragraphs, senderName, slug, acceptedAt, preview } = Astro.props;
---
<main class="min-h-screen w-full flex flex-col items-center justify-center px-6 py-16 text-center text-white font-sans" style="background:#b3122b;">
  <div class="w-full max-w-xl">
    <svg class="w-12 h-9 mx-auto mb-6" viewBox="0 0 64 40" fill="white" aria-hidden="true"><path d="M2 38h60l-5-25-13 9L32 3 20 22 7 13z"/></svg>
    <p class="text-[0.7rem] uppercase tracking-[0.5em] opacity-80 mb-6">Apologify</p>
    <h1 class="font-poster uppercase leading-[0.92] text-5xl sm:text-6xl tracking-wide mb-8" style="text-wrap: balance;">{title}</h1>
    <div class="mx-auto w-20 h-0.5 bg-white/60 mb-8"></div>
    {heading && <p class="text-lg font-medium mb-4">{heading}</p>}
    <div class="space-y-4 text-base sm:text-lg leading-relaxed text-white/90 text-left max-w-md mx-auto">
      {paragraphs.map((p: string) => <p set:html={p} />)}
    </div>
    {senderName && <p class="mt-8 text-2xl font-semibold">— {senderName}</p>}
    <div class="mt-10 flex justify-center">
      <ApologyActions client:load slug={slug} acceptedAt={acceptedAt} preview={preview}
        acceptLabel="Like this"
        primaryClass="px-7 py-3 bg-white text-[#b3122b] font-bold uppercase tracking-wide hover:bg-white/90 transition-colors"
        secondaryClass="px-6 py-3 border-2 border-white/70 text-white font-bold uppercase tracking-wide hover:bg-white/10 transition-colors"
        mutedClass="text-sm text-white/70" />
    </div>
    <a href="/generator" class="block mt-8 text-xs tracking-wide text-white/60 hover:text-white transition-colors">Made on apologify.com</a>
  </div>
</main>
