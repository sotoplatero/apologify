---
import ApologyActions from "../ApologyActions.svelte";
const { title, heading, paragraphs, senderName, slug, acceptedAt, preview } = Astro.props;
const words = String(title).split(/\s+/).filter(Boolean);
const sizes = ['text-4xl', 'text-6xl', 'text-5xl', 'text-7xl'];
---
<main class="min-h-screen w-full flex flex-col items-center justify-center px-6 py-16" style="background:#cdb892;">
  <div class="w-full max-w-xl bg-[#f3ead3] border-[6px] border-double border-[#5b4a2f] px-6 py-10 sm:px-10 sm:py-12 text-center text-[#3a2c17] shadow-[0_18px_50px_-20px_rgba(60,44,23,0.6)]">
    <p class="text-xs uppercase tracking-[0.4em]">Apologify presents</p>
    <div class="w-full h-1 bg-[#5b4a2f] my-3"></div>
    <div class="font-poster uppercase leading-[0.82] mb-2">
      {words.map((w: string, i: number) => <div class={`${sizes[i % sizes.length]} ${i % 2 ? 'text-[#a8341f]' : 'text-[#3a2c17]'}`}>{w}</div>)}
    </div>
    <div class="w-full h-1 bg-[#5b4a2f] my-3"></div>

    {heading && <p class="font-display text-lg mb-3">{heading}</p>}
    <div class="space-y-3 text-base leading-relaxed font-display text-[#4a3a22] text-left">
      {paragraphs.map((p: string) => <p set:html={p} />)}
    </div>
    {senderName && <p class="mt-6 text-3xl font-cursive text-[#7a5c34]">{senderName}</p>}

    <div class="mt-8 flex justify-center">
      <ApologyActions client:load slug={slug} acceptedAt={acceptedAt} preview={preview}
        acceptLabel="Accept this apology"
        primaryClass="px-7 py-3 bg-[#5b4a2f] text-[#f3ead3] font-poster uppercase tracking-wide hover:bg-[#3a2c17] transition-colors"
        secondaryClass="px-6 py-3 border-2 border-[#5b4a2f] text-[#5b4a2f] font-poster uppercase tracking-wide hover:bg-[#e3d5b5] transition-colors"
        mutedClass="text-sm text-[#7a5c34]" />
    </div>
  </div>
  <a href="/generator" class="block mt-8 text-xs tracking-wide text-[#5b4a2f]/70 hover:text-[#5b4a2f] transition-colors">Made on apologify.com</a>
</main>
