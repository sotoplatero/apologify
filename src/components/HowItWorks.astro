---
const steps = [
  {
    title: "Write it",
    description: "Tell us who it's for, what happened, and the tone. We turn it into a sincere, personal apology.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>`
  },
  {
    title: "Design it",
    description: "Pick a template — letter, cute, formal, vintage and more — and switch it live until it feels right.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828L9 21" />
          </svg>`
  },
  {
    title: "Share the link",
    description: "Publish and send them their own page — one they can open, accept, and share back.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>`
  },
//   {
//     title: "Generate",
//     description: "Our AI creates a personalized apology letter based on your inputs.",
//     icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
//             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
//           </svg>`
//   }
];
---

<section class="mb-32">
  <div class="text-center space-y-4 mb-16">
    <h2 class="text-4xl md:text-5xl font-bold text-gray-800 leading-tight tracking-tight">How It Works</h2>
    <p class="text-xl text-gray-600">From sorry to sent in under a minute.</p>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    {steps.map((step, index) => (
      <div class="group flex flex-col items-center text-center bg-white/80 backdrop-blur-sm shadow-lg rounded-2xl p-8 border-2 border-gray-200 hover:border-purple-300 transition-all duration-300 hover:scale-105 hover:shadow-xl">
        <div class="mb-6 bg-purple-100 rounded-full p-4 w-20 h-20 flex items-center justify-center group-hover:bg-purple-200 transition-colors duration-300">
          <div class="text-purple-600">
            <Fragment set:html={step.icon} />
          </div>
        </div>
        <div class="flex items-center justify-center mb-4">
          <span class="w-8 h-8 rounded-full bg-purple-600 text-white flex items-center justify-center text-sm font-bold mr-3">
            {index + 1}
          </span>
          <h3 class="text-2xl font-semibold text-gray-800 group-hover:text-purple-700 transition-colors duration-300">{step.title}</h3>
        </div>
        <p class="text-gray-600 text-lg leading-relaxed">{step.description}</p>
      </div>
    ))}
  </div>
</section> 