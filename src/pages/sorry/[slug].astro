---
import LayoutBase from "../../layouts/LayoutBase.astro";
import { getApologyPageBySlug } from "../../lib/apologyPages";
import { isLikelySlug } from "../../lib/slug.js";
import { apologyHeading, apologyParagraphsHtml } from "../../lib/display.js";
import LetterTemplate from "../../components/templates/LetterTemplate.astro";
import CuteTemplate from "../../components/templates/CuteTemplate.astro";
import StatementTemplate from "../../components/templates/StatementTemplate.astro";
import NightTemplate from "../../components/templates/NightTemplate.astro";

export const prerender = false;

const { slug } = Astro.params;
if (!slug || !isLikelySlug(slug)) return Astro.redirect("/404");
const page = await getApologyPageBySlug(slug);
if (!page) return Astro.redirect("/404");

// Preview (iframe) may override the template id so the drawer can hot-swap.
const preview = Astro.url.searchParams.get("preview") === "1";
const themeOverride = Astro.url.searchParams.get("theme");
const templateId = preview && themeOverride ? themeOverride : page.theme;

const TEMPLATES: Record<string, any> = {
  "classic": LetterTemplate,
  "cute-duck": CuteTemplate,
  "formal": StatementTemplate,
  "starry": NightTemplate,
};
const Template = TEMPLATES[templateId] || LetterTemplate;

const data = {
  title: page.title,
  heading: apologyHeading(page.recipientName),
  paragraphs: apologyParagraphsHtml(page.message),
  recipientName: page.recipientName,
  senderName: page.senderName,
  slug: page.slug,
  acceptedAt: page.acceptedAt,
  preview,
};

const noindex = preview || page.visibility !== "public";
const metaTitle = `${page.title} — An Apology | Apologify`;
const description = `${page.title} — a sincere apology${page.recipientName ? " for " + page.recipientName : ""}. Made on apologify.com.`.slice(0, 160);
const canonicalUrl = new URL("/sorry/" + page.slug, Astro.site).href;
const pageSchema = {
  "@context": "https://schema.org", "@type": "CreativeWork",
  headline: `${page.title} — Apology`, description, genre: page.tone,
  dateCreated: page.createdAt ? new Date(page.createdAt).toISOString() : undefined,
  author: { "@type": "Organization", name: "Apologify" },
  publisher: { "@type": "Organization", name: "Apologify", url: "https://apologify.com" },
};
---

<LayoutBase title={metaTitle} description={description} canonicalUrl={canonicalUrl} schema={[pageSchema]} noindex={noindex}>
  <Template {...data} />
</LayoutBase>
