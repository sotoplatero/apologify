---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import CallToAction from '../components/CallToAction.astro';
import { articles } from '@/lib/articles';
import { recipients } from '../lib/apologyData';
import { getLetterCount, getToneCounts, getSampleLetters } from '../lib/db';
import { listThemes } from '../lib/themes.js';

export const prerender = false;

const recentArticles = articles.slice(0, 3);
const themes = listThemes();
// Six featured designs for the home "See it live" grid (a diverse spread).
const featuredIds = ["classic", "handwritten", "cute-duck", "starry", "boarding-pass", "ransom"];
const featured = featuredIds
  .map((id) => themes.find((t) => t.id === id))
  .filter((t): t is (typeof themes)[number] => Boolean(t));

// Data from the DB
const [letterCount, toneCounts, sampleLetters] = await Promise.all([
  getLetterCount(),
  getToneCounts(),
  getSampleLetters(3)
]);

const uniqueTones = Object.keys(toneCounts);

// Iconos para recipients
const recipientIcons: Record<string, string> = {
  boss: "👔",
  client: "🤝",
  colleague: "👥",
  daughter: "👧",
  father: "👨",
  friend: "👫",
  husband: "💑",
  mother: "👩",
  romantic: "💕",
  partner: "💕",
  girlfriend: "💝",
  boyfriend: "💙",
  son: "👦",
  teacher: "📚",
  wife: "💑"
};

// Short descriptions for generator cards
const recipientDescriptions: Record<string, string> = {
  mother: "Mend the bond with heartfelt words",
  father: "Show respect and genuine regret",
  son: "Model accountability as a parent",
  daughter: "Reconnect with love and sincerity",
  wife: "Rebuild trust in your marriage",
  husband: "Express your love and commitment",
  friend: "Save a friendship that matters",
  partner: "Heal your relationship together",
  girlfriend: "Make things right with her",
  boyfriend: "Show him you truly care",
  boss: "Stay professional, stay sincere",
  colleague: "Restore your working relationship",
  client: "Maintain trust and professionalism",
  teacher: "Show respect for their role",
};

function truncateText(text: string, maxLength: number = 200): string {
  if (text.length <= maxLength) return text;
  const truncated = text.slice(0, maxLength);
  const lastSpace = truncated.lastIndexOf(' ');
  return truncated.slice(0, lastSpace) + '…';
}

// Schema.org structured data
const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Apologify",
  "alternateName": "Apologify.com",
  "url": "https://apologify.com",
  "description": "Write a heartfelt apology and turn it into a beautiful, shareable web page in seconds. Free apology website builder with multiple designs.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://apologify.com/examples?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Apologify",
  "url": "https://apologify.com",
  "logo": "https://apologify.com/favicon.svg",
  "description": "Apology website builder that turns heartfelt apologies into beautiful, shareable pages.",
  "sameAs": []
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does the apology website builder work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tell us who the apology is for, what happened, and the tone you want. Our AI writes a sincere, personal apology; you pick a design you love and switch it live; then you share it as its own web page — all in under a minute."
      }
    },
    {
      "@type": "Question",
      "name": "Who can see my apology?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "By default your page is a private draft — only people you send the link to can see it. It stays private until you decide to publish. Publishing makes it public and findable, and that is always your choice."
      }
    },
    {
      "@type": "Question",
      "name": "Can I apologize without using my name?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Leave the signature off and let the situation speak for itself. The page can be public while staying anonymous — only the person it is really for will recognize the moment."
      }
    },
    {
      "@type": "Question",
      "name": "Why would I make my apology public?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Publishing is a way to own it out loud — a clear signal you are not hiding from your mistake. It also helps others facing the same situation find the words. It is always optional."
      }
    },
    {
      "@type": "Question",
      "name": "Can I choose how the page looks?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Pick from designs like Letter, Cute, Statement, Night, Keep Calm, Swiss, Ransom, Constructivist and Letterpress, and switch between them live until it feels right. You can also edit the details and regenerate."
      }
    },
    {
      "@type": "Question",
      "name": "Is it free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Creating and sharing your apology page is free, no credit card required. Publishing it publicly just needs a free account. Some premium designs may require an upgrade later."
      }
    }
  ]
};
---

<Layout title="Apology Website Builder — Make a Sorry Page to Share Free" description="Write a heartfelt apology and turn it into a beautiful, shareable web page in seconds. Pick a design — letter, cute, formal, vintage and more — then send them the link. Free." schema={[webSiteSchema, organizationSchema, faqSchema]}>
  <Hero />

  <!-- ========================================== -->
  <!-- Why a page (problem → payoff)              -->
  <!-- ========================================== -->
  <section class="home-section">
    <div class="container mx-auto px-6">
      <div class="text-center space-y-3 mb-14">
        <span class="inline-block text-sm font-semibold tracking-widest uppercase text-primary font-sans">Why a page</span>
        <h2 class="font-display text-3xl md:text-5xl font-semibold text-base-content leading-tight tracking-tight" style="text-wrap: balance;">
          A text gets ignored. A template sounds fake.
        </h2>
        <p class="text-lg text-base-content/60 max-w-2xl mx-auto">
          When it really matters, the medium is the message. Here's what usually goes wrong — and what we do instead.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto">
        <div class="p-6 rounded-2xl border border-base-300 bg-base-200/50">
          <div class="w-11 h-11 rounded-xl bg-base-300/60 flex items-center justify-center text-base-content/50 mb-4">
            <svg class="w-5 h-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10.5h8M8 14h5M21 12a8 8 0 01-11.7 7.1L3 21l1.9-6.3A8 8 0 1121 12z"/></svg>
          </div>
          <h3 class="font-semibold text-base-content mb-1.5">A plain text</h3>
          <p class="text-sm text-base-content/60 leading-relaxed font-sans">Buried in the thread within the hour, and read as barely any effort at all.</p>
        </div>

        <div class="p-6 rounded-2xl border border-base-300 bg-base-200/50">
          <div class="w-11 h-11 rounded-xl bg-base-300/60 flex items-center justify-center text-base-content/50 mb-4">
            <svg class="w-5 h-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h8M8 11h8M8 15h5M6 3h9l5 5v13a1 1 0 01-1 1H6a1 1 0 01-1-1V4a1 1 0 011-1z"/></svg>
          </div>
          <h3 class="font-semibold text-base-content mb-1.5">A copied template</h3>
          <p class="text-sm text-base-content/60 leading-relaxed font-sans">Generic lines they've read a hundred times. They can tell it isn't really you.</p>
        </div>

        <div class="p-6 rounded-2xl border border-base-300 bg-base-200/50">
          <div class="w-11 h-11 rounded-xl bg-base-300/60 flex items-center justify-center text-base-content/50 mb-4">
            <svg class="w-5 h-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3h6v3H9zM4 21h16M12 6v3m-4 0h8a4 4 0 014 4v2a4 4 0 01-4 4H8a4 4 0 01-4-4v-2a4 4 0 014-4z"/></svg>
          </div>
          <h3 class="font-semibold text-base-content mb-1.5">A wall of AI text</h3>
          <p class="text-sm text-base-content/60 leading-relaxed font-sans">Decent words with nowhere to live — nothing you can actually give them.</p>
        </div>
      </div>

      <p class="text-center text-xl md:text-2xl text-base-content max-w-3xl mx-auto mt-12 leading-snug" style="text-wrap: balance;">
        Apologify gives you all three at once: <span class="text-primary font-semibold">words that sound like you</span>, a <span class="text-primary font-semibold">page that shows you cared</span>, and a <span class="text-primary font-semibold">link you know they opened</span>.
      </p>
    </div>
  </section>

  <!-- ========================================== -->
  <!-- Showcase: one apology, every design         -->
  <!-- ========================================== -->
  <section id="showcase" class="home-section scroll-mt-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-base-200 via-transparent to-transparent pointer-events-none"></div>
    <div class="container mx-auto px-6 relative">
      <div class="text-center space-y-3 mb-12">
        <span class="inline-block text-sm font-semibold tracking-widest uppercase text-primary font-sans">See it live</span>
        <h2 class="font-display text-3xl md:text-5xl font-semibold text-base-content leading-tight tracking-tight" style="text-wrap: balance;">
          One apology, {themes.length} ways to send it
        </h2>
        <p class="text-lg text-base-content/60 max-w-2xl mx-auto">
          Write it once, then switch the look until it feels like you — from a handwritten note to a front-page correction.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-5 sm:gap-7 max-w-5xl mx-auto">
        {featured.map((t) => (
          <a href="/designs" class="group block rounded-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-4 focus-visible:ring-offset-base-100">
            <div class="overflow-hidden rounded-xl">
              <img
                src={`/designs/${t.id}.jpg`}
                alt={`${t.label} apology page design`}
                loading="lazy"
                width="820"
                height="1040"
                class="w-full h-auto group-hover:scale-[1.02] transition-transform duration-500"
              />
            </div>
            <p class="mt-2.5 text-sm text-base-content/60 font-sans group-hover:text-base-content transition-colors"><span aria-hidden="true">{t.emoji}</span> {t.label}</p>
          </a>
        ))}
      </div>

      <div class="text-center mt-10 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/generator" class="btn btn-primary btn-lg">Make my apology page</a>
        <a href="/designs" class="btn btn-ghost btn-lg">See all {themes.length} designs →</a>
      </div>
    </div>
  </section>

  <main class="container mx-auto px-6">
    <!-- ========================================== -->
    <!-- How It Works                               -->
    <!-- ========================================== -->
    <div class="pt-16">
      <HowItWorks />
    </div>

    <!-- ========================================== -->
    <!-- Made in the open (public + reuse + library) -->
    <!-- ========================================== -->
    <section class="my-8">
      <div class="w-screen relative left-1/2 right-1/2 -mx-[50vw] bg-base-200 py-20 px-6">
        <div class="max-w-6xl mx-auto">
          <div class="text-center space-y-3 mb-14">
            <span class="inline-block text-sm font-semibold tracking-widest uppercase text-primary font-sans">Made in the open</span>
            <h2 class="font-display text-3xl md:text-5xl font-semibold text-base-content leading-tight tracking-tight" style="text-wrap: balance;">
              Real apologies, out in the open
            </h2>
            <p class="text-lg text-base-content/60 max-w-2xl mx-auto">
              Some people publish theirs — owning it in public, with no name required. Read {letterCount}+ real ones and start from one that fits your situation.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {sampleLetters.map((letter) => (
              <div class="group flex flex-col bg-base-100 shadow-md rounded-2xl overflow-hidden border border-base-300 hover:border-primary/40 transition-all duration-300 hover:shadow-xl">
                <div class="p-6 flex flex-col flex-1">
                  <div class="flex items-center gap-2 mb-4">
                    <span class="text-2xl" aria-hidden="true">{recipientIcons[letter.recipient] || "📝"}</span>
                    <span class="text-xs font-semibold uppercase tracking-wider text-primary bg-primary/10 px-3 py-1 rounded-full font-sans">
                      {letter.tone}
                    </span>
                  </div>
                  <h3 class="font-display text-lg font-semibold mb-3 text-base-content group-hover:text-primary transition-colors leading-snug">
                    {letter.title || `Apology to ${letter.recipient.charAt(0).toUpperCase() + letter.recipient.slice(1)}`}
                  </h3>
                  <p class="italic text-base-content/70 whitespace-pre-line leading-relaxed text-[15px] mb-5 line-clamp-4">
                    {truncateText(letter.letters[0])}
                  </p>
                  <a
                    href={`/examples/${letter.recipient}/${letter.slug}`}
                    class="mt-auto inline-flex items-center gap-2 text-primary hover:text-primary/80 font-medium text-sm font-sans transition-all duration-200 group-hover:gap-3"
                  >
                    <span>Read it &amp; make it yours</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                  </a>
                </div>
              </div>
            ))}
          </div>

          <div class="text-center mt-12">
            <a
              href="/examples"
              class="inline-flex items-center gap-2 px-7 py-3.5 bg-base-100 text-base-content/80 border-2 border-base-300 rounded-xl hover:border-primary hover:text-primary transition-all duration-300 font-medium shadow-sm hover:shadow-md font-sans"
            >
              <span>Browse all public apologies</span>
              <svg class="w-5 h-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========================================== -->
    <!-- By relationship (SEO entry points)         -->
    <!-- ========================================== -->
    <section class="my-28">
      <div class="text-center space-y-3 mb-14">
        <span class="inline-block text-sm font-semibold tracking-widest uppercase text-primary font-sans">By relationship</span>
        <h2 class="font-display text-3xl md:text-5xl font-semibold text-base-content leading-tight tracking-tight">
          Who do you need to apologize to?
        </h2>
        <p class="text-lg text-base-content/60 max-w-2xl mx-auto">
          Pick a relationship and the builder opens ready for them — write it, design it, and share the page.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {recipients.map(recipient => (
          <a
            href={`/generator/${recipient.value}`}
            class="group relative flex items-start gap-5 p-6 bg-base-100 rounded-2xl border border-base-300 hover:border-primary/50 shadow-sm hover:shadow-lg transition-all duration-300"
          >
            <div class="flex-shrink-0 w-14 h-14 rounded-xl bg-primary/10 group-hover:bg-primary/20 flex items-center justify-center text-3xl transition-colors duration-300" aria-hidden="true">
              {recipientIcons[recipient.value] || "📝"}
            </div>
            <div class="min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <h3 class="font-semibold text-base-content group-hover:text-primary transition-colors">
                  Apologize to Your {recipient.label}
                </h3>
                <svg class="w-4 h-4 text-base-content/30 group-hover:text-primary group-hover:translate-x-0.5 transition-all flex-shrink-0" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
              <p class="text-sm text-base-content/60 leading-relaxed font-sans">
                {recipientDescriptions[recipient.value] || "Generate a personalized apology"}
              </p>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/generator" class="btn btn-primary btn-lg">
          Or write a custom apology
        </a>
      </div>
    </section>

    <!-- ========================================== -->
    <!-- FAQ (privacy-first)                        -->
    <!-- ========================================== -->
    <section class="my-28">
      <div class="w-screen relative left-1/2 right-1/2 -mx-[50vw] bg-base-200 py-20">
        <div class="container mx-auto px-6">
          <div class="text-center space-y-3 mb-14">
            <span class="inline-block text-sm font-semibold tracking-widest uppercase text-primary font-sans">FAQ</span>
            <h2 class="font-display text-3xl md:text-5xl font-semibold text-base-content">Questions, answered</h2>
            <p class="text-lg text-base-content/60">Privacy, control, and how it all works.</p>
          </div>
          <div class="max-w-3xl mx-auto space-y-3">
            <details class="group bg-base-100 p-6 rounded-xl shadow-sm border border-base-300 hover:border-primary/40 transition-all">
              <summary class="font-semibold text-lg cursor-pointer flex justify-between items-center gap-4">
                <span>How does the apology website builder work?</span>
                <svg class="w-5 h-5 text-base-content/50 flex-shrink-0 transition-transform group-open:rotate-180" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-base-content/70 leading-relaxed font-sans">
                Tell us who the apology is for, what happened, and the tone you want. Our AI writes a sincere, personal apology; you pick a design you love and switch it live; then you share it as its own web page — all in under a minute.
              </p>
            </details>

            <details class="group bg-base-100 p-6 rounded-xl shadow-sm border border-base-300 hover:border-primary/40 transition-all">
              <summary class="font-semibold text-lg cursor-pointer flex justify-between items-center gap-4">
                <span>Who can see my apology?</span>
                <svg class="w-5 h-5 text-base-content/50 flex-shrink-0 transition-transform group-open:rotate-180" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-base-content/70 leading-relaxed font-sans">
                By default your page is a private draft — only people you send the link to can open it. It stays private until you decide to publish. Publishing makes it public and findable, and that's always your choice.
              </p>
            </details>

            <details class="group bg-base-100 p-6 rounded-xl shadow-sm border border-base-300 hover:border-primary/40 transition-all">
              <summary class="font-semibold text-lg cursor-pointer flex justify-between items-center gap-4">
                <span>Can I apologize without using my name?</span>
                <svg class="w-5 h-5 text-base-content/50 flex-shrink-0 transition-transform group-open:rotate-180" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-base-content/70 leading-relaxed font-sans">
                Yes. Leave the signature off and let the situation speak for itself. The page can be public while staying anonymous — only the person it's really for will recognize the moment.
              </p>
            </details>

            <details class="group bg-base-100 p-6 rounded-xl shadow-sm border border-base-300 hover:border-primary/40 transition-all">
              <summary class="font-semibold text-lg cursor-pointer flex justify-between items-center gap-4">
                <span>Why would I make my apology public?</span>
                <svg class="w-5 h-5 text-base-content/50 flex-shrink-0 transition-transform group-open:rotate-180" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-base-content/70 leading-relaxed font-sans">
                Publishing is a way to own it out loud — a clear signal you're not hiding from your mistake. It also helps someone in the same situation find the words. It's always optional.
              </p>
            </details>

            <details class="group bg-base-100 p-6 rounded-xl shadow-sm border border-base-300 hover:border-primary/40 transition-all">
              <summary class="font-semibold text-lg cursor-pointer flex justify-between items-center gap-4">
                <span>Can I choose how the page looks?</span>
                <svg class="w-5 h-5 text-base-content/50 flex-shrink-0 transition-transform group-open:rotate-180" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-base-content/70 leading-relaxed font-sans">
                Yes. Pick from designs like Letter, Cute, Statement, Night, Keep Calm, Swiss, Ransom, Constructivist and Letterpress, and switch between them live until it feels right. You can also edit the details and regenerate.
              </p>
            </details>

            <details class="group bg-base-100 p-6 rounded-xl shadow-sm border border-base-300 hover:border-primary/40 transition-all">
              <summary class="font-semibold text-lg cursor-pointer flex justify-between items-center gap-4">
                <span>Is it free?</span>
                <svg class="w-5 h-5 text-base-content/50 flex-shrink-0 transition-transform group-open:rotate-180" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-base-content/70 leading-relaxed font-sans">
                Creating and sharing your apology page is free, no credit card required. Choose from {uniqueTones.length} tones, and publishing publicly just needs a free account. Some premium designs may require an upgrade later.
              </p>
            </details>
          </div>
        </div>
      </div>
    </section>

    <!-- ========================================== -->
    <!-- Guides & Articles                          -->
    <!-- ========================================== -->
    <section class="my-28">
      <div class="text-center space-y-3 mb-14">
        <span class="inline-block text-sm font-semibold tracking-widest uppercase text-primary font-sans">Guides &amp; Tips</span>
        <h2 class="font-display text-3xl md:text-5xl font-semibold text-base-content leading-tight tracking-tight">Learn how to apologize the right way</h2>
        <p class="text-lg text-base-content/60 max-w-2xl mx-auto">Expert advice on crafting apologies that actually repair relationships.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-7">
        {recentArticles.map((article) => (
          <article class="group bg-base-100 shadow-md rounded-2xl overflow-hidden border border-base-300 hover:border-primary/40 transition-all duration-300 hover:shadow-xl">
            {article.data.image && (
              <div class="overflow-hidden aspect-video">
                <img src={article.data.image} alt={article.data.title} width="800" height="450" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
            )}
            <div class="p-6">
              <h3 class="font-display text-lg font-semibold mb-3 text-base-content group-hover:text-primary transition-colors duration-300 leading-snug line-clamp-2">
                <a href={`/articles/${article.slug}`}>
                  {article.data.title}
                </a>
              </h3>
              <a href={`/articles/${article.slug}`} class="inline-flex items-center gap-2 text-primary hover:text-primary/80 font-medium text-sm transition-all duration-200 group-hover:gap-3 font-sans">
                <span>Read article</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" aria-hidden="true" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/articles" class="btn btn-primary btn-lg">
          View all articles
        </a>
      </div>
    </section>

    <!-- ========================================== -->
    <!-- Final CTA                                  -->
    <!-- ========================================== -->
    <CallToAction />
  </main>
</Layout>

<style>
  .home-section {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }
</style>
