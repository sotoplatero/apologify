OPENAI_API_KEY=your_openai_api_key_here

# Turso Database (optional - for storing user-generated letters)
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your_turso_token_here

# Unsplash (optional - for article image generation)
# UNSPLASH_ACCESS_KEY=your_unsplash_key_here

# Better Auth
PUBLIC_SITE_URL=https://apologify.com
BETTER_AUTH_URL=http://localhost:4321
BETTER_AUTH_SECRET=replace-with-a-long-random-string

# Social auth (optional — each provider activates only if both vars are set).
# Callback URLs: ${BETTER_AUTH_URL}/api/auth/callback/google and /github
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
